<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Add Application | CareerTrack</title>

  <link rel="stylesheet" href="css/style.css" />
  <link rel="stylesheet" href="css/responsive.css" />
</head>
<body>

<header class="header">
  <nav class="navbar">
    <a href="/" class="logo">
      <div class="logo-icon">CT</div>
      <span>CareerTrack</span>
    </a>

    <ul class="nav-links" id="navLinks">
      <li><a href="/dashboard">Dashboard</a></li>
      <li><a href="/applications">Applications</a></li>
      <li><a href="/add-application" class="active-nav">Add Application</a></li>
      <li><a href="/profile">Profile</a></li>
      <li><a href="/login" class="login-btn">Logout</a></li>
    </ul>

    <button class="menu-btn" id="menuBtn">☰</button>
  </nav>
</header>

<main class="form-page">

  <section class="form-hero">
    <div>
      <p class="tagline">Create New Record</p>
      <h1>Add Job Application</h1>
      <p>Save company details, role, status, interview date and notes in one place.</p>
    </div>

    <a href="/applications" class="secondary-btn">View Applications</a>
  </section>

  <section class="application-form-card">

    <form id="applicationForm">

      <div class="form-grid">

        <div class="input-group">
          <label>Company Name *</label>
          <input type="text" id="companyName" placeholder="e.g. Accenture" />
          <small class="error-message" id="companyError"></small>
        </div>

        <div class="input-group">
          <label>Job Role *</label>
          <input type="text" id="jobRole" placeholder="e.g. Software Developer Intern" />
          <small class="error-message" id="roleError"></small>
        </div>

        <div class="input-group">
          <label>Job Type *</label>
          <select id="jobType">
            <option value="">Select Job Type</option>
            <option value="Internship">Internship</option>
            <option value="Full Time">Full Time</option>
            <option value="Part Time">Part Time</option>
            <option value="Remote">Remote</option>
            <option value="Contract">Contract</option>
          </select>
          <small class="error-message" id="typeError"></small>
        </div>

        <div class="input-group">
          <label>Location *</label>
          <input type="text" id="location" placeholder="e.g. Bangalore / Remote" />
          <small class="error-message" id="locationError"></small>
        </div>

        <div class="input-group">
          <label>Salary / Stipend</label>
          <input type="text" id="salary" placeholder="e.g. ₹15,000/month or ₹4 LPA" />
        </div>

        <div class="input-group">
          <label>Application Status *</label>
          <select id="status">
            <option value="">Select Status</option>
            <option value="Applied">Applied</option>
            <option value="Shortlisted">Shortlisted</option>
            <option value="Interview">Interview</option>
            <option value="Selected">Selected</option>
            <option value="Rejected">Rejected</option>
          </select>
          <small class="error-message" id="statusError"></small>
        </div>

        <div class="input-group">
          <label>Applied Date *</label>
          <input type="date" id="appliedDate" />
          <small class="error-message" id="appliedDateError"></small>
        </div>

        <div class="input-group">
          <label>Interview Date</label>
          <input type="date" id="interviewDate" />
        </div>

        <div class="input-group">
          <label>Job Source</label>
          <select id="source">
            <option value="">Select Source</option>
            <option value="LinkedIn">LinkedIn</option>
            <option value="Naukri">Naukri</option>
            <option value="Indeed">Indeed</option>
            <option value="Company Website">Company Website</option>
            <option value="Referral">Referral</option>
            <option value="Campus Placement">Campus Placement</option>
            <option value="Other">Other</option>
          </select>
        </div>

        <div class="input-group">
          <label>Priority</label>
          <select id="priority">
            <option value="Medium">Medium</option>
            <option value="High">High</option>
            <option value="Low">Low</option>
          </select>
        </div>

      </div>

      <div class="input-group">
        <label>Notes</label>
        <textarea id="notes" placeholder="Add interview round details, HR contact, follow-up reminder, etc."></textarea>
      </div>

      <div class="form-actions">
        <button type="reset" class="secondary-btn">Clear Form</button>
        <button type="submit" class="auth-btn" id="saveApplicationBtn">Save Application</button>
      </div>

    </form>

  </section>

</main>

<footer class="footer">
  <div>
    <h3>Career<span>Track</span></h3>
    <p>Track. Apply. Succeed.</p>
  </div>

  <div class="footer-links">
    <a href="/about">About</a>
    <a href="/contact">Contact</a>
    <a href="/terms">Terms</a>
    <a href="/privacy">Privacy</a>
  </div>

  <p class="copyright">© 2026 CareerTrack. All Rights Reserved.</p>
</footer>

<script src="js/main.js"></script>
<script src="js/applications.js"></script>
</body>
</html>