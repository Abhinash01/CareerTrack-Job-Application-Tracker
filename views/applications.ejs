<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Applications | CareerTrack</title>

  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/responsive.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
</head>
<body>

<%- include("./partials/app-navbar") %>

<main class="dashboard">

  <section class="dashboard-hero">
    <div>
      <p class="tagline">Application Records</p>
      <h1>Manage Your Applications</h1>
      <p>Search, filter, view and delete your saved job and internship applications.</p>
    </div>

    <a href="/add-application" class="primary-btn">+ Add Application</a>
  </section>

  <section class="dashboard-panel recent-section">

    <div class="panel-header">
      <h2>All Applications</h2>
      <span id="applicationCount">
        <%= applications ? applications.length : 0 %> Applications
      </span>
    </div>

    <form class="applications-tools" method="GET" action="/application">

  <input
    type="text"
    name="search"
    id="searchInput"
    placeholder="Search by company, role or location..."
    value="<%= search || '' %>"
  />

  <select id="statusFilter" name="status">
    <option value="All" <%= status === "All" ? "selected" : "" %>>All Status</option>
    <option value="Applied" <%= status === "Applied" ? "selected" : "" %>>Applied</option>
    <option value="Shortlisted" <%= status === "Shortlisted" ? "selected" : "" %>>Shortlisted</option>
    <option value="Interview" <%= status === "Interview" ? "selected" : "" %>>Interview</option>
    <option value="Selected" <%= status === "Selected" ? "selected" : "" %>>Selected</option>
    <option value="Rejected" <%= status === "Rejected" ? "selected" : "" %>>Rejected</option>
  </select>

  <button type="submit" class="primary-btn">
    Search
  </button>

  <a href="/applications" class="secondary-btn">
    Reset
  </a>

</form>

    <% if (applications && applications.length > 0) { %>
      <div class="table-wrapper">
        <table class="application-table">
          <thead>
            <tr>
              <th>Company</th>
              <th>Role</th>
              <th>Type</th>
              <th>Location</th>
              <th>Status</th>
              <th>Applied Date</th>
              <th>Action</th>
            </tr>
          </thead>

          <tbody id="applicationsTableBody">
            <% applications.forEach((app) => { %>
              <tr>
                <td><%= app.companyName %></td>
                <td><%= app.jobRole %></td>
                <td><%= app.jobType %></td>
                <td><%= app.location %></td>
                <td>
                  <span class="status <%= app.status.toLowerCase() %>">
                    <%= app.status %>
                  </span>
                </td>
                <td>
                  <%= app.appliedDate ? app.appliedDate.toISOString().split("T")[0] : "N/A" %>
                </td>
                <td>
                  <div class="action-buttons">
                    <a href="/application/edit/<%= app._id %>" class="small-btn edit-btn">Edit</a>
                    <form action="/application/delete/<%= app._id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this application?');">
                      <button type="submit" class="small-btn delete-btn">Delete</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="empty-state" id="emptyState" style="display: block;">
        <h3>No Applications Found</h3>
        <p>Add your first job or internship application to start tracking.</p>
        <a href="/add-application" class="primary-btn">Add Application</a>
      </div>
    <% } %>

  </section>

</main>

<%- include("./partials/footer") %>

<script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
<script src="/js/toast.js"></script>
</body>
</html>