<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Applications | CareerTrack</title>

  <link rel="stylesheet" href="css/style.css" />
  <link rel="stylesheet" href="css/responsive.css" />
</head>
<body>

<header class="header">
  <nav class="navbar">
    <a href="/" class="logo">
      <div class="logo-icon">CT</div>
      <span>CareerTrack</span>
    </a>

    <ul class="nav-links" id="navLinks">
      <li><a href="/dashboard">Dashboard</a></li>
      <li><a href="/applications" class="active-nav">Applications</a></li>
      <li><a href="/add-application">Add Application</a></li>
      <li><a href="/profile">Profile</a></li>
      <li><a href="/login" class="login-btn">Logout</a></li>
    </ul>

    <button class="menu-btn" id="menuBtn">☰</button>
  </nav>
</header>

<main class="dashboard">

  <section class="dashboard-hero">
    <div>
      <p class="tagline">Application Records</p>
      <h1>Manage Your Applications</h1>
      <p>Search, filter, view and delete your saved job and internship applications.</p>
    </div>

    <a href="/add-application" class="primary-btn">+ Add Application</a>
  </section>

  <section class="dashboard-panel recent-section">

    <div class="panel-header">
      <h2>All Applications</h2>
      <span id="applicationCount">0 Applications</span>
    </div>

    <div class="applications-tools">
      <input
        type="text"
        id="searchInput"
        placeholder="Search by company or role..."
      />

      <select id="statusFilter">
        <option value="All">All Status</option>
        <option value="Applied">Applied</option>
        <option value="Shortlisted">Shortlisted</option>
        <option value="Interview">Interview</option>
        <option value="Selected">Selected</option>
        <option value="Rejected">Rejected</option>
      </select>
    </div>

    <div class="table-wrapper">
      <table class="application-table">
        <thead>
          <tr>
            <th>Company</th>
            <th>Role</th>
            <th>Type</th>
            <th>Location</th>
            <th>Status</th>
            <th>Applied Date</th>
            <th>Action</th>
          </tr>
        </thead>

        <tbody id="applicationsTableBody"></tbody>
      </table>
    </div>

    <div class="empty-state" id="emptyState">
      <h3>No Applications Found</h3>
      <p>Add your first job or internship application to start tracking.</p>
      <a href="/add-application" class="primary-btn">Add Application</a>
    </div>

  </section>

</main>

<footer class="footer">
  <div>
    <h3>Career<span>Track</span></h3>
    <p>Track. Apply. Succeed.</p>
  </div>

  <div class="footer-links">
    <a href="/about">About</a>
    <a href="/contact">Contact</a>
    <a href="/terms">Terms</a>
    <a href="/privacy">Privacy</a>
  </div>

  <p class="copyright">© 2026 CareerTrack. All Rights Reserved.</p>
</footer>

<script src="js/main.js"></script>
<script src="js/applications.js"></script>
</body>
</html>