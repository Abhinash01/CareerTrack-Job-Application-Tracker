<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Profile | CareerTrack</title>

  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/responsive.css" />
</head>
<body>

<%- include("./partials/app-navbar") %>

<main class="profile-page">

  <section class="profile-hero">
    <div>
      <p class="tagline">User Profile</p>
      <h1>My Career Profile</h1>
      <p>View your account details and career application summary.</p>
    </div>
  </section>

  <section class="profile-grid">

    <div class="profile-card">
      <div class="profile-avatar">
        <%= user.fullName ? user.fullName.split(" ").map(n => n[0]).join("").toUpperCase().slice(0, 2) : "U" %>
      </div>

      <h2><%= user.fullName %></h2>
      <p><%= user.email %></p>

      <div class="profile-tags">
        <span>CareerTrack User</span>
        <span>Job Tracker</span>
      </div>

      <a href="/auth/logout" class="secondary-btn logout-link">Logout</a>
    </div>

    <div class="profile-details">

      <div class="dashboard-panel">
        <div class="panel-header">
          <h2>Account Information</h2>
          <span>Profile</span>
        </div>

        <div class="info-list">

          <div>
            <strong>👤 Full Name</strong>
            <p><%= user.fullName %></p>
          </div>

          <div>
            <strong>📧 Email Address</strong>
            <p><%= user.email %></p>
          </div>

          <div>
            <strong>📅 Member Since</strong>
            <p>
              <%= user.createdAt ? user.createdAt.toDateString() : "Not Available" %>
            </p>
          </div>

        </div>
      </div>

      <div class="dashboard-panel">
        <div class="panel-header">
          <h2>Career Summary</h2>
          <span>Stats</span>
        </div>

        <div class="profile-summary-grid">

          <div class="summary-card">
            <h3>📊 Total Applications</h3>
            <p><%= totalApplications %></p>
          </div>

          <div class="summary-card">
            <h3>🎤 Interviews</h3>
            <p><%= interviewCount %></p>
          </div>

          <div class="summary-card">
            <h3>🏆 Selected</h3>
            <p><%= selectedCount %></p>
          </div>

        </div>
      </div>

    </div>

  </section>

</main>

<%- include("./partials/footer") %>

<script src="/js/profile.js"></script>
</body>
</html>