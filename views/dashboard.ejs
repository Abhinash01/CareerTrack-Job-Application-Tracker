<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard | CareerTrack</title>

  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/responsive.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
</head>
<body>

<%- include("./partials/app-navbar") %>

<main class="dashboard">

  <section class="dashboard-hero">
    <div>
      <p class="tagline">Career Dashboard</p>
      <h1>Welcome to CareerTrack, <%= userName || "User" %></h1>
      <p>Track your applications, interviews, offers and progress in one place.</p>
    </div>

    <a href="/add-application" class="primary-btn">+ Add Application</a>
  </section>

  <section class="dashboard-stats">
    <div class="dash-card">
      <h3>Total Applications</h3>
      <h2><%= totalApplications %></h2>
      <p>All job and internship applications</p>
    </div>

    <div class="dash-card">
      <h3>Applied</h3>
      <h2><%= appliedCount %></h2>
      <p>Waiting for response</p>
    </div>

    <div class="dash-card">
      <h3>Interviews</h3>
      <h2><%= interviewCount %></h2>
      <p>Scheduled / completed interviews</p>
    </div>

    <div class="dash-card">
      <h3>Selected</h3>
      <h2><%= selectedCount %></h2>
      <p>Successful opportunities</p>
    </div>

    <div class="dash-card success-card">
      <h3>Success Rate</h3>
      <h2>
        <%= totalApplications ? Math.round((selectedCount / totalApplications) * 100) : 0 %>%
      </h2>
      <p>Based on selected applications</p>
    </div>
  </section>

<section class="dashboard-grid premium-dashboard-grid">

  <div class="dashboard-panel analytics-panel">
    <div class="panel-header">
      <div>
        <h2>Application Analytics</h2>
        <p>Visual overview of your application progress</p>
      </div>
      <span>This Month</span>
    </div>

    <div class="chart-container">
      <canvas
        id="statusChart"
        data-applied="<%= appliedCount %>"
        data-interview="<%= interviewCount %>"
        data-selected="<%= selectedCount %>"
        data-total="<%= totalApplications %>"
      ></canvas>
    </div>
  </div>

  <div class="dashboard-panel">
    <div class="panel-header">
      <div>
        <h2>Upcoming Interviews</h2>
        <p>Your interview reminders</p>
      </div>
      <span>Reminder</span>
    </div>

    <div class="interview-list">
      <% const upcomingInterviews = recentApplications ? recentApplications.filter(app => ["Interview", "Shortlisted"].includes(app.status)) : []; %>

      <% if (upcomingInterviews.length > 0) { %>
        <% upcomingInterviews.forEach((app) => { %>
          <div class="interview-item">
            <h3><%= app.companyName %></h3>
            <p><%= app.jobRole %></p>
            <span>
              <%= app.interviewDate ? app.interviewDate.toISOString().split("T")[0] : "Interview Scheduled" %>
            </span>
          </div>
        <% }) %>
      <% } else { %>
        <div class="interview-item">
          <h3>No Upcoming Interviews</h3>
          <p>Add interview applications to see reminders here.</p>
          <span>CareerTrack Reminder</span>
        </div>
      <% } %>
    </div>
  </div>

  <div class="dashboard-panel quote-panel">
    <div class="panel-header">
      <div>
        <h2>💡 Career Motivation</h2>
        <p>External API powered quote</p>
      </div>
      <span>API</span>
    </div>

    <div class="quote-box">
      <p id="quoteText">Loading quote...</p>
      <small id="quoteAuthor"></small>
    </div>
  </div>

</section>
  <section class="dashboard-panel">
  <div class="panel-header">
    <h2>Recent Activity</h2>
  </div>

  <div class="activity-list">

    <% if(recentApplications && recentApplications.length > 0){ %>

      <% recentApplications.slice(0,4).forEach(app => { %>

        <div class="activity-item">

          <span class="activity-dot"></span>

          <div>
            <h4>Applied to <%= app.companyName %></h4>

            <p>
              <%= app.jobRole %> • <%= app.status %>
            </p>
          </div>

        </div>

      <% }) %>

    <% } %>

  </div>
  </section>

  <section class="dashboard-panel recent-section">
    <div class="panel-header">
      <h2>Recent Applications</h2>
      <a href="/applications">View All</a>
    </div>

    <div class="table-wrapper">
      <table class="application-table">
        <thead>
          <tr>
            <th>Company</th>
            <th>Role</th>
            <th>Location</th>
            <th>Status</th>
            <th>Applied Date</th>
          </tr>
        </thead>

        <tbody>
          <% if (recentApplications && recentApplications.length > 0) { %>
            <% recentApplications.forEach((app) => { %>
              <tr>
                <td><%= app.companyName %></td>
                <td><%= app.jobRole %></td>
                <td><%= app.location %></td>
                <td>
                  <span class="status <%= app.status.toLowerCase() %>">
                    <%= app.status %>
                  </span>
                </td>
                <td>
                  <%= app.appliedDate ? app.appliedDate.toISOString().split("T")[0] : "N/A" %>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="5">No recent applications found.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="quick-actions">
    <a href="/add-application" class="action-card">
      <h3>➕ Add New</h3>
      <p>Add a new job or internship application.</p>
    </a>

    <a href="/applications" class="action-card">
      <h3>📋 View Applications</h3>
      <p>Manage all your saved applications.</p>
    </a>

    <a href="/profile" class="action-card">
      <h3>👤 Update Profile</h3>
      <p>Edit your profile and account details.</p>
    </a>
  </section>

</main>

<%- include("./partials/footer") %>



<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="/js/dashboard.js"></script>
<script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
<script src="/js/toast.js"></script>
</body>
</html>