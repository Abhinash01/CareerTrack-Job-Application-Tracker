<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Profile | CareerTrack</title>

  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/responsive.css" />
</head>
<body>

<%- include("./partials/app-navbar") %>

<main class="profile-page">

  <section class="profile-hero">
    <div>
      <p class="tagline">User Profile</p>
      <h1>Manage Your Career Profile</h1>
      <p>Keep your personal details, skills and career goals updated.</p>
    </div>
  </section>

  <section class="profile-grid">

    <div class="profile-card">
      <div class="profile-avatar">
      <%= user.fullName ? user.fullName.split(" ").map(n => n[0]).join("").toUpperCase().slice(0, 2) : "U" %>
      </div>
      <h2 id="profileName"><%= user.fullName %></h2>
      <p id="profileEmail"><%= user.email %></p>

      <div class="profile-tags">
        <span>MCA Student</span>
        <span>Full Stack Learner</span>
      </div>

      <button class="auth-btn" id="editProfileBtn">Edit Profile</button>
      <a href="/login" class="secondary-btn logout-link">Logout</a>
    </div>

    <div class="profile-details">

      <div class="dashboard-panel">
        <div class="panel-header">
          <h2>Personal Information</h2>
          <span>Profile</span>
        </div>

        <div class="info-list">
          <div>
            <strong>Full Name</strong>
            <p id="infoName"><%= user.fullName %></p>
          </div>

          <div>
            <strong>Email</strong>
            <p id="infoEmail"><%= user.email %></p>
          </div>

          <div>
            <strong>Phone</strong>
            <p>+91 98765 43210</p>
          </div>

          <div>
            <strong>Location</strong>
            <p>Cuttack, Odisha</p>
          </div>
        </div>
      </div>

      <div class="dashboard-panel">
        <div class="panel-header">
          <h2>Career Goal</h2>
          <span>Goal</span>
        </div>

        <p class="career-goal">
          I am focused on becoming a Full Stack Developer by building real-world projects
          using HTML, CSS, JavaScript, Node.js, Express.js and MongoDB.
        </p>
      </div>

      <div class="dashboard-panel">
        <div class="panel-header">
          <h2>Skills</h2>
          <span>Tech Stack</span>
        </div>

        <div class="skills-list">
          <span>HTML</span>
          <span>CSS</span>
          <span>JavaScript</span>
          <span>Node.js</span>
          <span>Express.js</span>
          <span>MongoDB</span>
          <span>GitHub</span>
          <span>Responsive Design</span>
        </div>
      </div>

    </div>

  </section>

</main>

<%- include("./partials/footer") %>


<script src="/js/profile.js"></script>
</body>
</html>