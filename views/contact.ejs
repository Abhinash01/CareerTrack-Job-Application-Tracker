<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Contact | CareerTrack</title>

  <link rel="stylesheet" href="css/style.css" />
  <link rel="stylesheet" href="css/responsive.css" />
</head>
<body>

<%- include("./partials/public-navbar") %>

<main>

  <section class="contact-hero">
    <p class="tagline">Contact Us</p>
    <h1>Need Help With CareerTrack?</h1>
    <p>
      Have questions, feedback, or suggestions? Send us a message and our team will get back to you.
    </p>
  </section>

  <section class="contact-section">

    <div class="contact-info">

      <div class="contact-card">
        <h3>📧 Email Support</h3>
        <p>abhinashgupta.mca2027@trident.ac.in</p>
        <span>For product queries and account support.</span>
      </div>

      <div class="contact-card">
        <h3>📍 Location</h3>
        <p>Cuttack, Odisha, India</p>
        <span>Built for students, freshers and job seekers.</span>
      </div>

      <div class="contact-card">
        <h3>⏰ Support Hours</h3>
        <p>Monday - Saturday</p>
        <span>10:00 AM to 6:00 PM</span>
      </div>

      <div class="contact-card">
        <h3>🚀 Project Type</h3>
        <p>Full Stack Web Application</p>
        <span>Frontend, Backend, Database and Authentication ready.</span>
      </div>

    </div>

    <div class="contact-form-card">

      <h2>Send a Message</h2>
      <p>Fill the form below and we will respond as soon as possible.</p>

      <form id="contactForm">

        <div class="input-group">
          <label>Full Name *</label>
          <input type="text" id="contactName" placeholder="Enter your full name" />
          <small class="error-message" id="contactNameError"></small>
        </div>

        <div class="input-group">
          <label>Email Address *</label>
          <input type="email" id="contactEmail" placeholder="Enter your email" />
          <small class="error-message" id="contactEmailError"></small>
        </div>

        <div class="input-group">
          <label>Subject *</label>
          <input type="text" id="contactSubject" placeholder="Enter subject" />
          <small class="error-message" id="contactSubjectError"></small>
        </div>

        <div class="input-group">
          <label>Message *</label>
          <textarea id="contactMessage" placeholder="Write your message here..."></textarea>
          <small class="error-message" id="contactMessageError"></small>
        </div>

        <button type="submit" class="auth-btn" id="contactBtn">
          Send Message
        </button>

      </form>

    </div>

  </section>

  <section class="support-section">
    <div class="section-title">
      <p>Support</p>
      <h2>How We Can Help</h2>
    </div>

    <div class="features-grid">
      <div class="feature-card">
        <h3>Account Help</h3>
        <p>Get support related to login, registration, profile and account access.</p>
      </div>

      <div class="feature-card">
        <h3>Application Tracking</h3>
        <p>Understand how to add, manage, search and filter your applications.</p>
      </div>

      <div class="feature-card">
        <h3>Feature Suggestions</h3>
        <p>Share ideas for reminders, analytics, notifications or dashboard improvements.</p>
      </div>
    </div>
  </section>

  <section class="cta">
    <h2>Start Tracking Your Career Journey</h2>
    <p>Create your free account and manage all applications from one dashboard.</p>
    <a href="/register" class="primary-btn">Get Started</a>
  </section>

</main>

<%- include("./partials/footer") %>

<script src="js/main.js"></script>
<script src="js/contact.js"></script>
</body>
</html>